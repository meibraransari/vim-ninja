# ============================================================
# VimNinja — Environment Variables
# Copy this file to .env and customize:
#   cp .env.example .env
# ============================================================

# Port the frontend is accessible on (default: 8080)
FRONTEND_PORT=8080

# Timezone (default: Asia/Kolkata)
TZ=Asia/Kolkata

# Domain for production (used if Caddy reverse proxy is enabled)
# DOMAIN=vimninja.yourdomain.com
